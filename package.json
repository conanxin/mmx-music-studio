{
  "name": "mmx-music-studio",
  "version": "0.4.1-alpha",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:server": "tsx server/index.ts",
    "dev:full": "bash scripts/dev-full.sh",
    "build": "tsc -b && vite build",
    "start": "tsx server/index.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:server": "tsc --noEmit -p server/tsconfig.json",
    "manifest:audit": "tsx scripts/manifest-audit.ts",
    "manifest:fix": "tsx scripts/manifest-fix.ts",
    "release:check": "bash scripts/release-check.sh",
    "preview": "vite preview",
    "weapp:dev": "npm --prefix apps/weapp run dev:weapp",
    "weapp:build": "node scripts/weapp-build.mjs",
    "weapp:typecheck": "npm --prefix apps/weapp run typecheck",
    "production:check": "bash scripts/production-readiness-check.sh"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
