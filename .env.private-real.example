# Private Real — 私有真实生成模式
# 真实调用 MiniMax mmx CLI，会消耗 Token Plan 额度
# ⚠️ 不建议在不限制访问的公网 IP 上裸奔使用

# 前置条件：
# 1. 服务器已安装 mmx CLI
# 2. 已运行 mmx auth login --recommend --region=cn
# 3. mmx quota 显示有可用额度

MINIMAX_API_KEY=<your_minimax_token_plan_key>
MINIMAX_REGION=cn
MINIMAX_BACKEND=cli

# 真实生成（必须）
REAL_GENERATION_ENABLED=true
MOCK_GENERATION_ENABLED=false

# 访问控制（建议开启）
PREVIEW_ACCESS_ENABLED=true
PREVIEW_ACCESS_PIN=<your_preview_pin>

# 服务器
HOST=0.0.0.0
PORT=8787
MUSIC_OUTPUT_DIR=./storage/tracks