# ── MiniMax API Key ────────────────────────────────────────────────────────────
# Your MiniMax Token Plan API key. Only used when REAL_GENERATION_ENABLED=true.
# Keep this file as a template — never commit real keys.
MINIMAX_API_KEY=<your_minimax_token_plan_key>

# ── Region ───────────────────────────────────────────────────────────────────
MINIMAX_REGION=cn

# ── Backend mode (Phase 2D) ─────────────────────────────────────────────────
# "mock" = local mock WAV (safe, no credits)
# "api"  = direct MiniMax API (experimental — Phase 2C showed service errors)
# "cli"  = mmx CLI adapter (recommended — requires mmx auth login)
# Note: Only used when REAL_GENERATION_ENABLED=true. Always defaults to "mock"
# when REAL_GENERATION_ENABLED=false (safe mode).
MINIMAX_BACKEND=mock

# ── Debug / Test-only ───────────────────────────────────────────────────────
# DO NOT enable in production.
# When true, /api/debug/reset-rate-limit and /api/debug/reset-daily-quota are available (204).
# When false (default), these endpoints return 404.
# Used only by smoke tests to reset in-memory state between test phases.
DEBUG_RESET_ENDPOINTS=false

# ── Storage ─────────────────────────────────────────────────────────────────
MUSIC_OUTPUT_DIR=./storage/tracks

# ── Preview Access Gate (Phase 2I) ───────────────────────────────────────────────
# PIN-based protection for public deployments. Default: disabled (false).
# When true, visitors must enter the correct PIN to access the application.
# PIN is read from PREVIEW_ACCESS_PIN env var — never stored in code or git.
PREVIEW_ACCESS_ENABLED=false
PREVIEW_ACCESS_PIN=<your_preview_pin>
# Optional: custom secret for cookie HMAC. If not set, derived from PIN + startup time.
PREVIEW_ACCESS_SECRET=<optional_secret>

# ── Generation Access Gate + Quota (Phase 4C) ──────────────────────────────────
# Protects /api/generate endpoint with a PIN-gated HMAC cookie.
# Prevents unauthorized users from triggering real music generation.
# Default: disabled (false). Enable before exposing to public.
GENERATION_ACCESS_ENABLED=false
GENERATION_ACCESS_PIN=<your_generation_pin>
# Cookie secret (optional): if not set, derived from PIN + startup time.
COOKIE_SECRET=<optional_cookie_secret>

# ── Rate Limit (Phase 4C) ──────────────────────────────────────────────────────
# Lightweight in-memory rate limiting per IP/session for /api/generate.
# Resets on server restart. Does not require storage.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=3

# ── Daily Generation Quota (Phase 4C) ──────────────────────────────────────────
# Limits total generations per calendar day (mock + CLI + API combined).
# Quota data stored in storage/quota/daily.json (gitignored).
# Recommended: set lower for public deployments, higher for personal use.
DAILY_QUOTA_ENABLED=true
DAILY_GENERATION_LIMIT=10

# ── Safety Switches (Phase 2B.2) ──────────────────────────────────────────────
#
# REAL_GENERATION_ENABLED: Default FALSE.
# When false, /api/generate uses the local mock adapter (WAV sine wave).
# Real MiniMax API is NEVER called, even if MINIMAX_API_KEY is set.
# Only set to true after explicit user confirmation — it consumes real credits.
REAL_GENERATION_ENABLED=false

# MOCK_GENERATION_ENABLED: Default TRUE.
# Set to false only if you want to disable mock adapter completely.
MOCK_GENERATION_ENABLED=true

# PUBLIC_DEMO_MODE: Optional extra guard for safe preview deployments.
# Does NOT affect security — realGenerationEnabled + backend=mock + mockGenerationEnabled
# are the authoritative safety conditions. This flag is an additional layer only.
PUBLIC_DEMO_MODE=false

# ── Auth Guard & Audit Logging (Phase 4F) ────────────────────────────────────
# PIN brute-force protection: locks out IP after repeated failed unlock attempts.
AUTH_GUARD_ENABLED=true
AUTH_GUARD_WINDOW_MS=300000
AUTH_GUARD_MAX_FAILURES=5
AUTH_GUARD_LOCK_MS=900000

# Audit logging: append-only JSONL to storage/audit/audit.jsonl.
AUDIT_LOG_ENABLED=true
AUDIT_LOG_DIR=./storage/audit

# ── BYOK Mode (Phase 5A) ───────────────────────────────────────────────────────
# BYOK = Bring Your Own Key. Users supply their own MiniMax Token Plan key
# via the web UI. The key is sent via x-minimax-api-key header, stored only
# in server memory (Map) for the duration of the job, and never written to disk.
#
# BYOK_ENABLED: enable BYOK mode. When true, users can enter their own key.
BYOK_ENABLED=false

# SERVER_KEY_FALLBACK: if true and no BYOK key provided, fall back to server's
# MINIMAX_API_KEY. If false (recommended), reject requests without a BYOK key.
# Default: false (safer — no silent server key usage).
SERVER_KEY_FALLBACK=false

# BYOK_KEY_STORAGE: currently only "memory" is supported.
# Keys are stored in a Node.js Map with 30-minute TTL, never to disk.
BYOK_KEY_STORAGE=memory

# ── Real API Attempt Guard (Phase 5B-C) ───────────────────────────────────────
# Hard protection that counts BEFORE the network call (not after success).
# Prevents "99 failed retries = 99 real API calls" problem.
# Only effective when REAL_GENERATION_ENABLED=true.
# If enabled with limit=1: at most 1 real MiniMax API call per calendar day.
REAL_API_ATTEMPT_LIMIT_ENABLED=false
REAL_API_DAILY_ATTEMPT_LIMIT=1

# ── Phase Launch Guard-A: Public Generation Guardrails ────────────────────────
# Lightweight public alpha guardrails to protect server and quota.
# Does NOT affect Library or playback — only generation requests.
PUBLIC_GENERATION_GUARD_ENABLED=true
PUBLIC_GENERATION_ENABLED=true
PER_SOURCE_DAILY_GENERATION_LIMIT=5
GENERATION_COOLDOWN_SECONDS=30
